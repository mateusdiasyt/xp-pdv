generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  WITHDRAWAL
  SUPPLY
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum PaymentStatus {
  APPROVED
  CANCELLED
  REFUNDED
  DIVERGENT
}

enum RefundStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  FAILED
}

enum ProductKind {
  STANDARD
  GAMEPLAY
  SERVICE
}

enum StockUnit {
  UNIT
  MILLILITER
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum GameplayReleaseStatus {
  LIBERADA
  PAUSADA
  CANCELADA
  PENDENTE_ENVIO
  FALHA_ENVIO
}

enum ServiceDeclarationStatus {
  DECLARED
  CANCELLED
}

enum CustomerDocumentType {
  CPF
  RG
}

enum ComandaStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum AccountPayableStatus {
  PENDING
  PAID
}

enum PlatformTenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
  FAILED
}

model BusinessUnit {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  categories     ProductCategory[]
  suppliers      Supplier[]
  products       Product[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]

  @@index([name])
}

model Role {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles           RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  status       RecordStatus @default(ACTIVE)
  roleId       String
  unitId       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  role      Role          @relation(fields: [roleId], references: [id])
  unit      BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  auditLogs AuditLog[]

  stockMovements             StockMovement[]            @relation("MovementOperator")
  cashSessions               CashSession[]              @relation("CashSessionOperator")
  cashMovements              CashMovement[]             @relation("CashMovementOperator")
  sales                      Sale[]                     @relation("SaleOperator")
  cancelledSales             Sale[]                     @relation("SaleCancelledBy")
  saleCancellations          SaleCancellation[]         @relation("SaleCancellationCreatedBy")
  directPermissions          UserPermission[]
  createdGoals               DailyGoal[]                @relation("GoalCreatedBy")
  createdMonthlyGoalPlans    MonthlyGoalPlan[]          @relation("MonthlyGoalPlanCreatedBy")
  openedComandas             Comanda[]                  @relation("ComandaOpenedBy")
  closedComandas             Comanda[]                  @relation("ComandaClosedBy")
  uploadedStockXmls          StockInvoiceXml[]          @relation("StockInvoiceXmlUploadedBy")
  createdSystemUpdates       SystemUpdate[]             @relation("SystemUpdateCreatedBy")
  updatedBrandCustomizations BrandCustomization[]       @relation("BrandCustomizationUpdatedBy")
  serviceFiscalDeclarations  ServiceFiscalDeclaration[] @relation("ServiceFiscalDeclarationCreatedBy")

  @@index([status])
  @@index([roleId])
  @@index([unitId])
}

model UserPermission {
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model ProductCategory {
  id               String       @id @default(cuid())
  name             String
  slug             String
  description      String?
  fiscalCfop       String?
  fiscalCsosn      String?
  fiscalIcmsOrigin String?
  status           RecordStatus @default(ACTIVE)
  unitId           String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  unit             BusinessUnit?    @relation(fields: [unitId], references: [id], onDelete: SetNull)
  products         Product[]
  couponLinks      CouponCategory[]
  entryGoals       DailyGoal[]      @relation("GoalEntryCategory")
  consumptionGoals DailyGoal[]      @relation("GoalConsumptionCategory")

  @@unique([slug, unitId])
  @@index([status])
}

model Supplier {
  id        String       @id @default(cuid())
  tradeName String
  legalName String?
  document  String?
  email     String?
  phone     String?
  status    RecordStatus @default(ACTIVE)
  unitId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  unit     BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  products Product[]

  @@index([tradeName])
  @@index([status])
}

model Product {
  id                      String       @id @default(cuid())
  name                    String
  sku                     String       @unique
  ncm                     String?
  fiscalCfop              String?
  fiscalCsosn             String?
  fiscalIcmsOrigin        String?
  description             String?
  imageUrl                String?
  kind                    ProductKind  @default(STANDARD)
  gameplayPlanCode        String?
  gameplayDurationMinutes Int?
  serviceCnae             String?
  serviceDescription      String?
  costPrice               Decimal      @db.Decimal(12, 4)
  salePrice               Decimal      @db.Decimal(12, 2)
  happyHourPrice          Decimal?     @db.Decimal(12, 2)
  marginPercent           Decimal      @default(0) @db.Decimal(5, 2)
  minStock                Int          @default(0)
  currentStock            Int          @default(0)
  stockUnit               StockUnit    @default(UNIT)
  tracksStock             Boolean      @default(true)
  pdvVisible              Boolean      @default(true)
  status                  RecordStatus @default(ACTIVE)
  categoryId              String
  supplierId              String?
  unitId                  String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id])
  supplier Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  unit     BusinessUnit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)

  stockMovements    StockMovement[]
  saleItems         SaleItem[]
  comandaItems      ComandaItem[]
  couponLinks       CouponProduct[]
  recipeIngredients ProductRecipeIngredient[] @relation("RecipeProduct")
  ingredientUses    ProductRecipeIngredient[] @relation("RecipeIngredient")

  @@index([name])
  @@index([categoryId])
  @@index([supplierId])
  @@index([status])
  @@index([kind])
  @@index([tracksStock])
  @@index([serviceCnae])
  @@index([unitId])
}

model ProductRecipeIngredient {
  id                  String   @id @default(cuid())
  productId           String
  ingredientProductId String
  quantity            Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  product           Product @relation("RecipeProduct", fields: [productId], references: [id], onDelete: Cascade)
  ingredientProduct Product @relation("RecipeIngredient", fields: [ingredientProductId], references: [id], onDelete: Restrict)

  @@unique([productId, ingredientProductId])
  @@index([ingredientProductId])
}

model Coupon {
  id                String             @id @default(cuid())
  code              String             @unique
  name              String
  description       String?
  discountType      CouponDiscountType
  discountValue     Decimal            @db.Decimal(12, 2)
  maxDiscountAmount Decimal?           @db.Decimal(12, 2)
  minSubtotalAmount Decimal?           @db.Decimal(12, 2)
  usageLimit        Int?
  usedCount         Int                @default(0)
  startsAt          DateTime?
  endsAt            DateTime?
  status            RecordStatus       @default(ACTIVE)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  products   CouponProduct[]
  categories CouponCategory[]
  sales      SaleCoupon[]

  @@index([status])
  @@index([startsAt, endsAt])
}

model CouponCategory {
  couponId   String
  categoryId String

  coupon   Coupon          @relation(fields: [couponId], references: [id], onDelete: Cascade)
  category ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([couponId, categoryId])
  @@index([categoryId])
}

model CouponProduct {
  couponId  String
  productId String

  coupon  Coupon  @relation(fields: [couponId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([couponId, productId])
  @@index([productId])
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  type           StockMovementType
  quantity       Int
  unitCost       Decimal?          @db.Decimal(12, 4)
  previousStock  Int
  resultingStock Int
  note           String?
  operatorId     String?
  unitId         String?
  createdAt      DateTime          @default(now())

  product  Product       @relation(fields: [productId], references: [id])
  operator User?         @relation("MovementOperator", fields: [operatorId], references: [id], onDelete: SetNull)
  unit     BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([type])
  @@index([unitId])
}

model StockInvoiceXml {
  id               String    @id @default(cuid())
  accessKey        String    @unique
  invoiceNumber    String?
  invoiceSeries    String?
  supplierName     String?
  supplierDocument String?
  issuedAt         DateTime?
  totalAmount      Decimal?  @db.Decimal(12, 2)
  itemCount        Int       @default(0)
  rawXml           String
  sourceFileName   String
  sourceFileSize   Int
  uploadedById     String?
  createdAt        DateTime  @default(now())

  uploadedBy User? @relation("StockInvoiceXmlUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([invoiceNumber, invoiceSeries])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model CashRegister {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  status    RecordStatus @default(ACTIVE)
  unitId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  unit     BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  sessions CashSession[]

  @@index([status])
  @@index([unitId])
}

model CashSession {
  id               String            @id @default(cuid())
  cashRegisterId   String
  operatorId       String
  status           CashSessionStatus @default(OPEN)
  openingAmount    Decimal           @db.Decimal(12, 2)
  expectedAmount   Decimal?          @db.Decimal(12, 2)
  closingAmount    Decimal?          @db.Decimal(12, 2)
  differenceAmount Decimal?          @db.Decimal(12, 2)
  note             String?
  openedAt         DateTime          @default(now())
  closedAt         DateTime?

  cashRegister CashRegister   @relation(fields: [cashRegisterId], references: [id])
  operator     User           @relation("CashSessionOperator", fields: [operatorId], references: [id])
  movements    CashMovement[]
  sales        Sale[]

  @@index([cashRegisterId, status])
  @@index([openedAt])
}

model CashMovement {
  id            String           @id @default(cuid())
  cashSessionId String
  operatorId    String?
  type          CashMovementType
  amount        Decimal          @db.Decimal(12, 2)
  reason        String
  createdAt     DateTime         @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  operator    User?       @relation("CashMovementOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([cashSessionId, createdAt])
}

model Sale {
  id                 String     @id @default(cuid())
  saleNumber         String     @unique
  cashSessionId      String
  operatorId         String
  customerName       String?
  subtotalAmount     Decimal    @db.Decimal(12, 2)
  discountAmount     Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal    @db.Decimal(12, 2)
  status             SaleStatus @default(COMPLETED)
  fiscalReference    String?
  fiscalDocumentType String?
  fiscalEnvironment  String?
  fiscalStatus       String?
  fiscalMessage      String?
  fiscalAccessKey    String?
  fiscalProtocol     String?
  fiscalNumber       String?
  fiscalSeries       String?
  fiscalXmlUrl       String?
  fiscalDanfeUrl     String?
  fiscalQrCodeUrl    String?
  fiscalConsultaUrl  String?
  fiscalIssuedAt     DateTime?
  fiscalUpdatedAt    DateTime?
  fiscalErrorAt      DateTime?
  fiscalResponse     Json?
  cancelReason       String?
  cancelledAt        DateTime?
  cancelledById      String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  cashSession     CashSession       @relation(fields: [cashSessionId], references: [id])
  operator        User              @relation("SaleOperator", fields: [operatorId], references: [id])
  cancelledBy     User?             @relation("SaleCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  items           SaleItem[]
  payments        Payment[]
  coupons         SaleCoupon[]
  closedComanda   Comanda?          @relation("ComandaClosedSale")
  gameplayRelease GameplayRelease?
  cancellation    SaleCancellation?

  @@index([cashSessionId, createdAt])
  @@index([operatorId])
  @@index([status])
  @@index([fiscalReference])
  @@index([fiscalStatus])
}

model SaleCoupon {
  id                    String             @id @default(cuid())
  saleId                String
  couponId              String
  codeSnapshot          String
  discountTypeSnapshot  CouponDiscountType
  discountValueSnapshot Decimal            @db.Decimal(12, 2)
  discountAmount        Decimal            @db.Decimal(12, 2)
  createdAt             DateTime           @default(now())

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([couponId])
}

model Customer {
  id             String               @id @default(cuid())
  fullName       String
  birthDate      DateTime?            @db.Date
  documentType   CustomerDocumentType
  documentNumber String
  phone          String?
  email          String?
  status         RecordStatus         @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  comandas Comanda[]

  @@unique([documentType, documentNumber])
  @@index([fullName])
  @@index([status])
}

model Comanda {
  id                   String        @id @default(cuid())
  number               Int
  status               ComandaStatus @default(OPEN)
  isWalkIn             Boolean       @default(false)
  customerId           String?
  customerNameSnapshot String?
  subtotalAmount       Decimal       @default(0) @db.Decimal(12, 2)
  notes                String?
  openedById           String
  closedById           String?
  closedSaleId         String?       @unique
  openedAt             DateTime      @default(now())
  closedAt             DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  customer   Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  openedBy   User          @relation("ComandaOpenedBy", fields: [openedById], references: [id])
  closedBy   User?         @relation("ComandaClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  closedSale Sale?         @relation("ComandaClosedSale", fields: [closedSaleId], references: [id], onDelete: SetNull)
  items      ComandaItem[]

  @@index([number, status])
  @@index([openedAt])
}

model ComandaItem {
  id        String   @id @default(cuid())
  comandaId String
  productId String
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  lineTotal Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comanda Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([comandaId, productId])
  @@index([comandaId])
  @@index([productId])
}

model SaleItem {
  id                         String      @id @default(cuid())
  saleId                     String
  productId                  String
  productNameSnapshot        String
  skuSnapshot                String
  ncmSnapshot                String?
  fiscalCfopSnapshot         String?
  fiscalCsosnSnapshot        String?
  fiscalIcmsOriginSnapshot   String?
  productKindSnapshot        ProductKind @default(STANDARD)
  serviceCnaeSnapshot        String?
  serviceDescriptionSnapshot String?
  serviceDeclarationId       String?
  serviceDeclaredAt          DateTime?
  gameplayStationId          String?
  gameplayPlanCode           String?
  gameplayDurationMinutes    Int?
  quantity                   Int
  unitPrice                  Decimal     @db.Decimal(12, 2)
  unitCost                   Decimal     @db.Decimal(12, 2)
  lineTotal                  Decimal     @db.Decimal(12, 2)
  lineCostTotal              Decimal     @db.Decimal(12, 2)
  createdAt                  DateTime    @default(now())

  sale               Sale                      @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product            Product                   @relation(fields: [productId], references: [id])
  serviceDeclaration ServiceFiscalDeclaration? @relation(fields: [serviceDeclarationId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([productId])
  @@index([productKindSnapshot])
  @@index([serviceCnaeSnapshot])
  @@index([serviceDeclarationId])
}

model ServiceFiscalDeclaration {
  id                 String                   @id @default(cuid())
  serviceCnae        String
  serviceDescription String
  periodStart        DateTime                 @db.Date
  periodEnd          DateTime                 @db.Date
  totalAmount        Decimal                  @db.Decimal(12, 2)
  itemCount          Int
  nfseNumber         String?
  nfseIssuedAt       DateTime?                @db.Date
  notes              String?
  status             ServiceDeclarationStatus @default(DECLARED)
  createdById        String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  createdBy User?      @relation("ServiceFiscalDeclarationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items     SaleItem[]

  @@index([serviceCnae, periodStart, periodEnd])
  @@index([status])
  @@index([createdById])
}

model GameplayRelease {
  id                 String                @id @default(cuid())
  saleId             String?               @unique
  integrationId      String                @default("pdv-xp-main")
  stationId          String
  planCode           String
  durationMinutes    Int
  amount             Decimal               @db.Decimal(12, 2)
  paidAt             DateTime
  operator           String
  customerId         String?
  requestPayload     Json
  responsePayload    Json?
  status             GameplayReleaseStatus @default(PENDENTE_ENVIO)
  attempts           Int                   @default(0)
  lastError          String?
  serviceStartsAt    DateTime?
  preparationSeconds Int                   @default(30)
  releasedUntil      DateTime?
  lastAttemptAt      DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  sale Sale? @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
  @@index([stationId])
  @@index([stationId, releasedUntil])
}

model Payment {
  id                    String        @id @default(cuid())
  saleId                String
  method                PaymentMethod
  amount                Decimal       @db.Decimal(12, 2)
  status                PaymentStatus @default(APPROVED)
  approvedAmount        Decimal?      @db.Decimal(12, 2)
  cardBrand             String?
  cardLast4             String?
  nsu                   String?
  authorizationCode     String?
  terminalId            String?
  externalTransactionId String?
  receiptText           String?
  auditNote             String?
  processedAt           DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @default(now()) @updatedAt

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method])
  @@index([status])
  @@index([nsu])
  @@index([authorizationCode])
  @@index([externalTransactionId])
  @@index([terminalId, createdAt])
}

model SaleCancellation {
  id                          String         @id @default(cuid())
  saleId                      String         @unique
  reason                      String
  refundStatus                RefundStatus   @default(PENDING)
  refundMethod                PaymentMethod?
  refundAmount                Decimal        @default(0) @db.Decimal(12, 2)
  refundNsu                   String?
  refundAuthorizationCode     String?
  refundTerminalId            String?
  refundExternalTransactionId String?
  refundReceiptText           String?
  fiscalStatus                String?
  fiscalMessage               String?
  stockRestored               Boolean        @default(false)
  createdById                 String?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  sale      Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  createdBy User? @relation("SaleCancellationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([refundStatus])
  @@index([refundMethod])
  @@index([createdAt])
  @@index([createdById])
}

model DailyGoal {
  id                     String   @id @default(cuid())
  goalDate               DateTime @unique @db.Date
  entryTicketsTarget     Int      @default(0)
  consumptionSalesTarget Decimal  @default(0) @db.Decimal(12, 2)
  entryCategoryId        String?
  consumptionCategoryId  String?
  notes                  String?
  createdById            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  entryCategory       ProductCategory? @relation("GoalEntryCategory", fields: [entryCategoryId], references: [id], onDelete: SetNull)
  consumptionCategory ProductCategory? @relation("GoalConsumptionCategory", fields: [consumptionCategoryId], references: [id], onDelete: SetNull)
  createdBy           User?            @relation("GoalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([goalDate])
  @@index([entryCategoryId])
  @@index([consumptionCategoryId])
}

model MonthlyGoalPlan {
  id                   String   @id @default(cuid())
  monthStart           DateTime @unique @db.Date
  companyCost          Decimal  @db.Decimal(12, 2)
  desiredProfitPercent Decimal  @db.Decimal(5, 2)
  monthlyRevenueTarget Decimal  @db.Decimal(12, 2)
  dailyRevenueTarget   Decimal  @db.Decimal(12, 2)
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  createdBy User? @relation("MonthlyGoalPlanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([monthStart])
}

model SupportTicket {
  id              String                @id @default(cuid())
  ticketNumber    String                @unique
  title           String
  description     String
  attachmentImage String?
  priority        SupportTicketPriority @default(MEDIUM)
  status          SupportTicketStatus   @default(OPEN)
  createdById     String?
  createdByName   String
  updatedById     String?
  updatedByName   String?
  resolvedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status, createdAt])
  @@index([priority])
}

model AccountPayable {
  id                 String               @id @default(cuid())
  name               String
  amount             Decimal              @db.Decimal(12, 2)
  dueDate            DateTime             @db.Date
  isRecurringMonthly Boolean              @default(false)
  dueDay             Int?
  status             AccountPayableStatus @default(PENDING)
  installmentNumber  Int                  @default(1)
  installmentTotal   Int                  @default(1)
  notes              String?
  receiptDataUrl     String?
  receiptFileName    String?
  receiptMimeType    String?
  paidAt             DateTime?
  createdById        String?
  updatedById        String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([status, dueDate])
  @@index([isRecurringMonthly, dueDay])
  @@index([dueDate])
  @@index([createdAt])
}

model PlatformTenant {
  id                     String               @id @default(cuid())
  name                   String
  slug                   String               @unique
  status                 PlatformTenantStatus @default(PENDING)
  planName               String?
  planStatus             String               @default("pending")
  planExpiresAt          DateTime?
  ownerName              String
  ownerEmail             String
  ownerDocument          String?
  ownerWhatsapp          String?
  ownerPasswordHash      String?
  databaseName           String?              @unique
  databaseUrlEncrypted   String?
  isDefault              Boolean              @default(false)
  approvedAt             DateTime?
  suspendedAt            DateTime?
  companyNameConfirmedAt DateTime?
  customSlugUpdatedAt    DateTime?
  lastProvisioningError  String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  users PlatformTenantUser[]

  @@index([status])
  @@index([ownerEmail])
  @@index([isDefault])
}

model PlatformTenantUser {
  id              String   @id @default(cuid())
  tenantId        String
  email           String
  name            String
  role            String   @default("owner")
  isOwner         Boolean  @default(false)
  isPlatformAdmin Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant PlatformTenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([email])
}

model PlatformGatewayConfiguration {
  id                   String    @id @default(cuid())
  provider             String    @unique @default("mercado-pago")
  environment          String    @default("test")
  publicKey            String?
  accessTokenEncrypted String?
  status               String    @default("inactive")
  lastTestStatus       String?
  lastTestMessage      String?
  lastTestedAt         DateTime?
  updatedById          String?
  updatedByName        String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([provider])
  @@index([status])
}

model SystemUpdate {
  id            String   @id @default(cuid())
  title         String
  description   String
  createdById   String?
  createdByName String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  createdBy User? @relation("SystemUpdateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model FiscalConfiguration {
  id                         String   @id @default(cuid())
  scope                      String   @unique @default("GLOBAL")
  environment                String   @default("homologacao")
  cnpjEmitente               String?
  defaultNcm                 String?
  tokenHomologEncrypted      String?
  tokenProductionEncrypted   String?
  nfceHomologSeries          String?
  nfceHomologNextNumber      Int?
  nfceHomologIdToken         String?
  nfceHomologCscEncrypted    String?
  nfceProductionSeries       String?
  nfceProductionNextNumber   Int?
  nfceProductionIdToken      String?
  nfceProductionCscEncrypted String?
  updatedById                String?
  updatedByName              String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@index([updatedAt])
}

model PdvConfiguration {
  id                 String    @id @default(cuid())
  scope              String    @unique @default("GLOBAL")
  happyHourActive    Boolean   @default(false)
  happyHourUpdatedAt DateTime?
  updatedById        String?
  updatedByName      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([updatedAt])
}

model BrandCustomization {
  id                  String   @id @default(cuid())
  browserTitle        String   @default("PDV - XP Arcade e Bar")
  primaryColor        String   @default("#d4a62a")
  accentColor         String   @default("#b9882a")
  backgroundColor     String   @default("#0a0a0a")
  foregroundColor     String   @default("#f4efe4")
  logoDataUrl         String?
  faviconDataUrl      String?
  businessTimezone    String   @default("America/Sao_Paulo")
  businessDayStartsAt String   @default("19:00")
  businessDayEndsAt   String   @default("01:00")
  updatedById         String?
  updatedByName       String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  updatedBy User? @relation("BrandCustomizationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}
