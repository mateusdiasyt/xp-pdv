generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  WITHDRAWAL
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum SaleStatus {
  COMPLETED
  CANCELLED
}

enum CustomerDocumentType {
  CPF
  RG
}

enum ComandaStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

model BusinessUnit {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  categories     ProductCategory[]
  suppliers      Supplier[]
  products       Product[]
  stockMovements StockMovement[]
  cashRegisters  CashRegister[]

  @@index([name])
}

model Role {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now())

  roles           RolePermission[]
  userPermissions UserPermission[]
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  status       RecordStatus @default(ACTIVE)
  roleId       String
  unitId       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  role      Role         @relation(fields: [roleId], references: [id])
  unit      BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  auditLogs AuditLog[]

  stockMovements StockMovement[] @relation("MovementOperator")
  cashSessions   CashSession[]   @relation("CashSessionOperator")
  cashMovements  CashMovement[]  @relation("CashMovementOperator")
  sales          Sale[]          @relation("SaleOperator")
  cancelledSales Sale[]          @relation("SaleCancelledBy")
  directPermissions UserPermission[]
  createdGoals   DailyGoal[]     @relation("GoalCreatedBy")
  createdMonthlyGoalPlans MonthlyGoalPlan[] @relation("MonthlyGoalPlanCreatedBy")
  openedComandas Comanda[] @relation("ComandaOpenedBy")
  closedComandas Comanda[] @relation("ComandaClosedBy")
  uploadedStockXmls StockInvoiceXml[] @relation("StockInvoiceXmlUploadedBy")
  createdSystemUpdates SystemUpdate[] @relation("SystemUpdateCreatedBy")
  updatedBrandCustomizations BrandCustomization[] @relation("BrandCustomizationUpdatedBy")

  @@index([status])
  @@index([roleId])
  @@index([unitId])
}

model UserPermission {
  userId       String
  permissionId String

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
}

model ProductCategory {
  id          String       @id @default(cuid())
  name        String
  slug        String
  description String?
  status      RecordStatus @default(ACTIVE)
  unitId      String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  unit     BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  products Product[]
  entryGoals DailyGoal[]       @relation("GoalEntryCategory")
  consumptionGoals DailyGoal[] @relation("GoalConsumptionCategory")

  @@unique([slug, unitId])
  @@index([status])
}

model Supplier {
  id         String       @id @default(cuid())
  tradeName  String
  legalName  String?
  document   String?
  email      String?
  phone      String?
  status     RecordStatus @default(ACTIVE)
  unitId     String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  unit     BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  products Product[]

  @@index([tradeName])
  @@index([status])
}

model Product {
  id            String       @id @default(cuid())
  name          String
  sku           String       @unique
  ncm           String?
  description   String?
  imageUrl      String?
  costPrice     Decimal      @db.Decimal(12, 2)
  salePrice     Decimal      @db.Decimal(12, 2)
  marginPercent Decimal      @default(0) @db.Decimal(5, 2)
  minStock      Int          @default(0)
  currentStock  Int          @default(0)
  status        RecordStatus @default(ACTIVE)
  categoryId    String
  supplierId    String?
  unitId        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  category ProductCategory @relation(fields: [categoryId], references: [id])
  supplier Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  unit     BusinessUnit?   @relation(fields: [unitId], references: [id], onDelete: SetNull)

  stockMovements StockMovement[]
  saleItems      SaleItem[]
  comandaItems   ComandaItem[]

  @@index([name])
  @@index([categoryId])
  @@index([supplierId])
  @@index([status])
  @@index([unitId])
}

model StockMovement {
  id             String            @id @default(cuid())
  productId      String
  type           StockMovementType
  quantity       Int
  unitCost       Decimal?          @db.Decimal(12, 2)
  previousStock  Int
  resultingStock Int
  note           String?
  operatorId     String?
  unitId         String?
  createdAt      DateTime          @default(now())

  product  Product       @relation(fields: [productId], references: [id])
  operator User?         @relation("MovementOperator", fields: [operatorId], references: [id], onDelete: SetNull)
  unit     BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([type])
  @@index([unitId])
}

model StockInvoiceXml {
  id               String   @id @default(cuid())
  accessKey        String   @unique
  invoiceNumber    String?
  invoiceSeries    String?
  supplierName     String?
  supplierDocument String?
  issuedAt         DateTime?
  totalAmount      Decimal? @db.Decimal(12, 2)
  itemCount        Int      @default(0)
  rawXml           String
  sourceFileName   String
  sourceFileSize   Int
  uploadedById     String?
  createdAt        DateTime @default(now())

  uploadedBy User? @relation("StockInvoiceXmlUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([invoiceNumber, invoiceSeries])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

model CashRegister {
  id        String       @id @default(cuid())
  name      String
  code      String       @unique
  status    RecordStatus @default(ACTIVE)
  unitId    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  unit     BusinessUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  sessions CashSession[]

  @@index([status])
  @@index([unitId])
}

model CashSession {
  id               String            @id @default(cuid())
  cashRegisterId   String
  operatorId       String
  status           CashSessionStatus @default(OPEN)
  openingAmount    Decimal           @db.Decimal(12, 2)
  expectedAmount   Decimal?          @db.Decimal(12, 2)
  closingAmount    Decimal?          @db.Decimal(12, 2)
  differenceAmount Decimal?          @db.Decimal(12, 2)
  note             String?
  openedAt         DateTime          @default(now())
  closedAt         DateTime?

  cashRegister CashRegister   @relation(fields: [cashRegisterId], references: [id])
  operator     User           @relation("CashSessionOperator", fields: [operatorId], references: [id])
  movements    CashMovement[]
  sales        Sale[]

  @@index([cashRegisterId, status])
  @@index([openedAt])
}

model CashMovement {
  id          String           @id @default(cuid())
  cashSessionId String
  operatorId  String?
  type        CashMovementType
  amount      Decimal          @db.Decimal(12, 2)
  reason      String
  createdAt   DateTime         @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)
  operator    User?       @relation("CashMovementOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([cashSessionId, createdAt])
}

model Sale {
  id             String     @id @default(cuid())
  saleNumber     String     @unique
  cashSessionId  String
  operatorId     String
  customerName   String?
  subtotalAmount Decimal    @db.Decimal(12, 2)
  discountAmount Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal    @db.Decimal(12, 2)
  status         SaleStatus @default(COMPLETED)
  fiscalReference    String?
  fiscalDocumentType String?
  fiscalEnvironment  String?
  fiscalStatus       String?
  fiscalMessage      String?
  fiscalAccessKey    String?
  fiscalProtocol     String?
  fiscalNumber       String?
  fiscalSeries       String?
  fiscalXmlUrl       String?
  fiscalDanfeUrl     String?
  fiscalQrCodeUrl    String?
  fiscalConsultaUrl  String?
  fiscalIssuedAt     DateTime?
  fiscalUpdatedAt    DateTime?
  fiscalErrorAt      DateTime?
  fiscalResponse     Json?
  cancelReason   String?
  cancelledAt    DateTime?
  cancelledById  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  cashSession CashSession @relation(fields: [cashSessionId], references: [id])
  operator    User        @relation("SaleOperator", fields: [operatorId], references: [id])
  cancelledBy User?       @relation("SaleCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  items       SaleItem[]
  payments    Payment[]
  closedComanda Comanda? @relation("ComandaClosedSale")

  @@index([cashSessionId, createdAt])
  @@index([operatorId])
  @@index([status])
  @@index([fiscalReference])
  @@index([fiscalStatus])
}

model Customer {
  id             String               @id @default(cuid())
  fullName       String
  birthDate      DateTime?            @db.Date
  documentType   CustomerDocumentType
  documentNumber String
  phone          String?
  email          String?
  status         RecordStatus         @default(ACTIVE)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  comandas Comanda[]

  @@unique([documentType, documentNumber])
  @@index([fullName])
  @@index([status])
}

model Comanda {
  id                 String        @id @default(cuid())
  number             Int
  status             ComandaStatus @default(OPEN)
  isWalkIn           Boolean       @default(false)
  customerId         String?
  customerNameSnapshot String?
  subtotalAmount     Decimal       @default(0) @db.Decimal(12, 2)
  notes              String?
  openedById         String
  closedById         String?
  closedSaleId       String?       @unique
  openedAt           DateTime      @default(now())
  closedAt           DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  openedBy   User      @relation("ComandaOpenedBy", fields: [openedById], references: [id])
  closedBy   User?     @relation("ComandaClosedBy", fields: [closedById], references: [id], onDelete: SetNull)
  closedSale Sale?     @relation("ComandaClosedSale", fields: [closedSaleId], references: [id], onDelete: SetNull)
  items      ComandaItem[]

  @@index([number, status])
  @@index([openedAt])
}

model ComandaItem {
  id         String   @id @default(cuid())
  comandaId  String
  productId  String
  quantity   Int
  unitPrice  Decimal  @db.Decimal(12, 2)
  lineTotal  Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  comanda Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@unique([comandaId, productId])
  @@index([comandaId])
  @@index([productId])
}

model SaleItem {
  id                  String   @id @default(cuid())
  saleId              String
  productId           String
  productNameSnapshot String
  skuSnapshot         String
  ncmSnapshot         String?
  quantity            Int
  unitPrice           Decimal  @db.Decimal(12, 2)
  unitCost            Decimal  @db.Decimal(12, 2)
  lineTotal           Decimal  @db.Decimal(12, 2)
  lineCostTotal       Decimal  @db.Decimal(12, 2)
  createdAt           DateTime @default(now())

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(cuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  createdAt DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([method])
}

model DailyGoal {
  id                     String    @id @default(cuid())
  goalDate               DateTime  @unique @db.Date
  entryTicketsTarget     Int       @default(0)
  consumptionSalesTarget Decimal   @default(0) @db.Decimal(12, 2)
  entryCategoryId        String?
  consumptionCategoryId  String?
  notes                  String?
  createdById            String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  entryCategory       ProductCategory? @relation("GoalEntryCategory", fields: [entryCategoryId], references: [id], onDelete: SetNull)
  consumptionCategory ProductCategory? @relation("GoalConsumptionCategory", fields: [consumptionCategoryId], references: [id], onDelete: SetNull)
  createdBy           User?            @relation("GoalCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([goalDate])
  @@index([entryCategoryId])
  @@index([consumptionCategoryId])
}

model MonthlyGoalPlan {
  id                   String   @id @default(cuid())
  monthStart           DateTime @unique @db.Date
  companyCost          Decimal  @db.Decimal(12, 2)
  desiredProfitPercent Decimal  @db.Decimal(5, 2)
  monthlyRevenueTarget Decimal  @db.Decimal(12, 2)
  dailyRevenueTarget   Decimal  @db.Decimal(12, 2)
  createdById          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  createdBy User? @relation("MonthlyGoalPlanCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([monthStart])
}

model SupportTicket {
  id            String               @id @default(cuid())
  ticketNumber  String               @unique
  title         String
  description   String
  attachmentImage String?
  priority      SupportTicketPriority @default(MEDIUM)
  status        SupportTicketStatus   @default(OPEN)
  createdById   String?
  createdByName String
  updatedById   String?
  updatedByName String?
  resolvedAt    DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status, createdAt])
  @@index([priority])
}

model SystemUpdate {
  id          String   @id @default(cuid())
  title       String
  description String
  createdById String?
  createdByName String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User? @relation("SystemUpdateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model FiscalConfiguration {
  id           String   @id @default(cuid())
  scope        String   @unique @default("GLOBAL")
  environment  String   @default("homologacao")
  updatedById  String?
  updatedByName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([updatedAt])
}

model BrandCustomization {
  id              String   @id @default(cuid())
  primaryColor    String   @default("#d4a62a")
  accentColor     String   @default("#b9882a")
  backgroundColor String   @default("#0a0a0a")
  foregroundColor String   @default("#f4efe4")
  logoDataUrl     String?
  faviconDataUrl  String?
  updatedById     String?
  updatedByName   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  updatedBy User? @relation("BrandCustomizationUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedAt])
}
